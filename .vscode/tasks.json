{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Luca Lights.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/LTEK ULed.Desktop/LucaLights.csproj",
                "-c",
                "Release",
                "-o",
                "${workspaceFolder}/publish",
                "-r",
                "linux-x64",
                "--self-contained",
                "true"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
