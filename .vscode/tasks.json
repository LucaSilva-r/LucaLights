{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Luca Lights.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/LTEK ULed.Desktop/LucaLights.csproj",
                "-c",
                "Release",
                "-o",
                "${workspaceFolder}/publish",
                "-r",
                "linux-x64",
                "--self-contained",
                "true"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish AppImage",
            "type": "shell",
            "command": "dotnet publish '${workspaceFolder}/LTEK ULed.Desktop/LucaLights.csproj' -c Release -o '${workspaceFolder}/publish' -r linux-x64 --self-contained true && DOTNET_ROOT=${HOME}/.dotnet ${HOME}/.dotnet/tools/vpk pack -u LucaLights -v 1.0.0 -p '${workspaceFolder}/publish' -e LucaLights --icon '${workspaceFolder}/Assets/logo.png'",
            "problemMatcher": [],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
