{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch LucaLights",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/LTEK ULed.Desktop/bin/Debug/net10.0/LucaLights",
            "args": [],
            "cwd": "${workspaceFolder}",
            "env": {
                "DOTNET_ROOT": "${env:HOME}/.dotnet"
            },
            "console": "internalConsole",
            "stopAtEntry": false
        },
        {
            "name": "Attach to Process",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
