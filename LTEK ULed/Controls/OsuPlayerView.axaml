<UserControl xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="using:LTEK_ULed.ViewModels"
	mc:Ignorable="d"
	x:Class="LTEK_ULed.Controls.OsuPlayerView"
	x:DataType="vm:OsuPlayerViewModel">

	<StackPanel Spacing="8">
		<!-- Connection Status -->
		<DockPanel>
			<Ellipse DockPanel.Dock="Left" Width="10" Height="10" Margin="0,0,8,0"
					 Fill="Green" IsVisible="{Binding IsConnected}"/>
			<Ellipse DockPanel.Dock="Left" Width="10" Height="10" Margin="0,0,8,0"
					 Fill="Gray" IsVisible="{Binding !IsConnected}"/>
			<TextBlock VerticalAlignment="Center" Text="{Binding StatusText}"/>
		</DockPanel>

		<!-- Now Playing -->
		<TextBlock Text="{Binding NowPlayingText}" FontWeight="Bold" FontSize="14"
				   TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxLines="2"/>

		<!-- Progress -->
		<DockPanel>
			<TextBlock DockPanel.Dock="Left" Text="{Binding CurrentTimeFormatted}" Width="40"/>
			<TextBlock DockPanel.Dock="Right" Text="{Binding TotalTimeFormatted}" Width="40" TextAlignment="Right"/>
			<Slider Minimum="0" Maximum="{Binding TotalLengthMs}" Value="{Binding CurrentPositionMs}"
					IsEnabled="False" Margin="5,0"/>
		</DockPanel>

		<!-- Column Mappings -->
		<DockPanel Margin="0,3">
			<TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,8,0">Mappings:</TextBlock>
			<Button DockPanel.Dock="Right" Command="{Binding OpenMappingsDialogCommand}" Content="Configure" Classes="Secondary"/>
			<NumericUpDown DockPanel.Dock="Right" Value="{Binding MappingKeyCount}" Minimum="1" Maximum="18"
						   FormatString="0" Width="80" Margin="0,0,8,0"/>
			<TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,5,0" Text="K" Opacity="0.7"/>
		</DockPanel>

		<!-- Info -->
		<TextBlock Opacity="0.5" FontSize="11" TextWrapping="Wrap"
				   Text="Connect tosu and play an osu!mania beatmap. Lights will sync automatically."/>
	</StackPanel>
</UserControl>
